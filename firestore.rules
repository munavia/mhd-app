rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function callerData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /** Use Map.get so missing `role` / `status` on legacy user docs does not break rule evaluation. */
    function callerRole() {
      return callerData().get('role', 'user');
    }

    function callerIsBlocked() {
      return request.auth != null &&
        callerData().get('status', 'active') == 'blocked';
    }

    function isAdmin() {
      return request.auth != null && !callerIsBlocked() && callerRole() == 'admin';
    }

    /** Admin or contributor (contributor matches admin capabilities except user role updates). */
    function isAdminOrContributor() {
      return request.auth != null && !callerIsBlocked() && callerRole() in ['admin', 'contributor'];
    }

    function isStaffPostEditor() {
      return request.auth != null && !callerIsBlocked() && callerRole() in ['admin', 'editor', 'contributor'];
    }

    // Users — admin may update any user (role/status). Others may update only themselves, not role/status.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        isAdmin() ||
        (request.auth.uid == userId &&
         !callerIsBlocked() &&
         request.resource.data.get('role', 'user') == resource.data.get('role', 'user') &&
         request.resource.data.get('status', 'active') == resource.data.get('status', 'active'))
      );
    }

    match /posts/{postId} {
      allow read: if resource.data.status == 'published' ||
        (request.auth != null && !callerIsBlocked() && (
          resource.data.authorId == request.auth.uid ||
          isStaffPostEditor()
        ));
      allow create: if request.auth != null && isStaffPostEditor();
      allow update: if request.auth != null && !callerIsBlocked() && (
        resource.data.authorId == request.auth.uid ||
        isStaffPostEditor()
      );
      allow delete: if request.auth != null && (
        (resource.data.authorId == request.auth.uid && isStaffPostEditor()) ||
        isAdminOrContributor()
      );
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null && !callerIsBlocked() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.content.size() <= 2000;
      allow delete: if request.auth != null && !callerIsBlocked() && (
        resource.data.userId == request.auth.uid ||
        isStaffPostEditor()
      );
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null && !callerIsBlocked() &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && !callerIsBlocked() &&
        resource.data.userId == request.auth.uid;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, delete: if request.auth != null && isStaffPostEditor();
    }

    match /prayerRequests/{prayerDocId} {
      allow create: if request.auth != null && !callerIsBlocked();
      allow read, update, delete: if request.auth != null && isAdminOrContributor();
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && isAdminOrContributor();
    }

    match /sermons/{sermonId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isStaffPostEditor();
    }

    match /programs/{programId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isStaffPostEditor();
    }

    match /upcomingEvents/{eventId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isStaffPostEditor();
    }
  }
}
