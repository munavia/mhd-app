rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && callerRole() == 'admin';
    }

    /** Admin or contributor (contributor matches admin capabilities except user role updates). */
    function isAdminOrContributor() {
      return request.auth != null && callerRole() in ['admin', 'contributor'];
    }

    function isStaffPostEditor() {
      return request.auth != null && callerRole() in ['admin', 'editor', 'contributor'];
    }

    // Users — only admin may update another user's document (e.g. role). Others may update only themselves.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin()
      );
    }

    match /posts/{postId} {
      allow read: if resource.data.status == 'published' ||
        (request.auth != null && (
          resource.data.authorId == request.auth.uid ||
          isStaffPostEditor()
        ));
      allow create: if request.auth != null && isStaffPostEditor();
      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        isStaffPostEditor()
      );
      allow delete: if request.auth != null && (
        (resource.data.authorId == request.auth.uid && isStaffPostEditor()) ||
        isAdminOrContributor()
      );
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.content.size() <= 2000;
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isStaffPostEditor()
      );
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, delete: if request.auth != null && isStaffPostEditor();
    }

    match /prayerRequests/{prayerDocId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && isAdminOrContributor();
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && isAdminOrContributor();
    }
  }
}
